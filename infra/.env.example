# Copy to .env and fill in secrets:
#   cp .env.example .env

# --- Postgres (local via docker compose) ---
POSTGRES_USER=verity
POSTGRES_PASSWORD=verity
POSTGRES_DB=verity
POSTGRES_PORT=5432
DATABASE_URL=postgresql://verity:verity@localhost:5432/verity

# --- Agent service (/services/agent) ---
ANTHROPIC_API_KEY=

