# Copy to .env and fill in secrets:
#   cp .env.example .env

# --- Postgres (local via docker compose) ---
POSTGRES_USER=verity
POSTGRES_PASSWORD=verity
POSTGRES_DB=verity
POSTGRES_PORT=5432
DATABASE_URL=postgresql://verity:verity@localhost:5432/verity

# --- Agent service (/services/agent) ---
ANTHROPIC_API_KEY=
MCP_SERVER_URL=http://localhost:8001/mcp
BRAINTRUST_API_KEY=
BRAINTRUST_PROJECT=verity

# --- MCP server (/services/mcp) ---
MCP_HOST=0.0.0.0
MCP_PORT=8001

# --- Frontend (/apps/web) ---
AGENT_API_URL=http://localhost:8000
# Vercel production: set to your Railway agent URL, e.g. https://verity-agent.up.railway.app
