# Copy to .env and fill in secrets:
#   cp .env.example .env

# --- Postgres (local via docker compose) ---
POSTGRES_USER=verity
POSTGRES_PASSWORD=verity
POSTGRES_DB=verity
POSTGRES_PORT=5432
DATABASE_URL=postgresql://verity:verity@localhost:5432/verity

# --- Agent service (/services/agent) ---
ANTHROPIC_API_KEY=
MCP_SERVER_URL=http://localhost:8001/mcp
BRAINTRUST_API_KEY=
BRAINTRUST_PROJECT=verity
# Optional shared secret. When set, POST /reconcile requires Authorization: Bearer <key>.
# Leave empty for local open access; set in production and mirror on Vercel as AGENT_API_KEY.
AGENT_API_KEY=
# Production fail-closed: set true on Railway so unset AGENT_API_KEY refuses requests.
# Leave false (or unset) locally.
AGENT_REQUIRE_API_KEY=false
# Optional tuning (defaults are fine for local demo).
# MCP_HTTP_TIMEOUT_SECONDS=30
# MCP_SSE_READ_TIMEOUT_SECONDS=120
# ANTHROPIC_TIMEOUT_SECONDS=90
# RECONCILE_RATE_LIMIT=20
# RECONCILE_RATE_WINDOW_SECONDS=60

# --- MCP server (/services/mcp) ---
MCP_HOST=0.0.0.0
MCP_PORT=8001

# --- Frontend (/apps/web) ---
AGENT_API_URL=http://localhost:8000
# Same value as AGENT_API_KEY above when auth is enabled (server-side only — never NEXT_PUBLIC_).
AGENT_API_KEY=
# Vercel production: set to your Railway agent URL, e.g. https://verity-agent.up.railway.app
